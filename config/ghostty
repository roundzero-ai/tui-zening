# Ghostty config - tui_zening (appearance + behavior only)
# Deploy: setup.sh copies this to
#   macOS: ~/Library/Application Support/com.mitchellh.ghostty/config
#   Linux: ~/.config/ghostty/config
# Reference: https://ghostty.org/docs/config
#
# Keybindings are NOT defined here. The tmux/Ghostty keymap layer lives in
# tmux-zengarden/ghostty-keys.conf (single source of truth for the whole
# ZenGarden keymap); setup.sh deploys it alongside this file as
# zengarden-keys.conf, pulled in by the config-file include at the bottom.

#theme             = "light:Alabaster,dark:Bright Lights"
theme             = "Bright Lights"
font-family       = "JetBrainsMono NFM Regular"
font-size         = 13
adjust-cell-height = 1%

mouse-scroll-multiplier = 2
mouse-hide-while-typing = true
focus-follows-mouse     = true
cursor-style            = block
copy-on-select          = clipboard

window-padding-x       = 5
window-padding-y       = 5
window-colorspace      = "display-p3"
window-decoration      = true
window-padding-balance = true
window-save-state      = always

macos-titlebar-style = transparent
background-opacity   = 0.8
background-blur      = 90

# tmux ZenGarden keymap layer (deployed by setup.sh from tmux-zengarden).
# Leading ? makes the include optional so Ghostty still starts if it's absent.
config-file = ?zengarden-keys.conf
