# ── Paste-safe settings ───────────────────────────────────────
# Prevent pasted content from being reformatted or mangled

# No auto-indent: pasted indentation is preserved as-is
unset autoindent

# No line wrapping: long lines are not broken mid-paste
set nowrap

# ── Display ───────────────────────────────────────────────────
# Show line numbers
set linenumbers

# Keep config compatible with older nano builds
# (some distros do not support the `smooth` option)
